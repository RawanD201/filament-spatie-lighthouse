{
    "name": "rawand201/filament-spatie-lighthouse",
    "description": "A Filament plugin for running and viewing Google Lighthouse audit results",
    "keywords": [
        "filament",
        "filament-plugin",
        "lighthouse",
        "performance",
        "audit",
        "seo",
        "accessibility",
        "laravel"
    ],
    "homepage": "https://github.com/Rawand201/filament-spatie-lighthouse",
    "license": "MIT",
    "authors": [
        {
            "name": "Rawand",
            "email": "rawandrasool@proton.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/lighthouse-php": "^2.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "FilamentSpatieLighthouse\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FilamentSpatieLighthouse\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilamentSpatieLighthouse\\FilamentSpatieLighthouseServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}